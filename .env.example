# ======================================================================
# HIME — Environment Configuration
# Copy this file to .env and fill in your values.
# All values shown are defaults unless marked as REQUIRED.
# ======================================================================

# DATA_RETENTION_DAYS=30  # Rolling retention window for health data (default 30)

# -----------------------------------------------------------------------
# LLM Providers (fill in the key(s) for the provider you want to use)
# -----------------------------------------------------------------------
# Primary Providers
GEMINI_API_KEY=               # Gemini (recommended)
GOOGLE_API_KEY=               # Google AI (used by config.py for Gemini / Google providers)
OPENAI_API_KEY=               # GPT-4.5 / GPT-5
ANTHROPIC_API_KEY=            # Claude 3.5 / 4.5

# OpenAI-Compatible Providers
DEEPSEEK_API_KEY=             # DeepSeek (V3/R1)
GROQ_API_KEY=                 # Groq
MISTRAL_API_KEY=              # Mistral AI
MINIMAX_API_KEY=              # MiniMax
XAI_API_KEY=                  # x.AI (Grok)
OPENROUTER_API_KEY=           # OpenRouter
PERPLEXITY_API_KEY=           # Perplexity

# vLLM local server — set VLLM_MODEL to match your served model.
# Requires a local GPU with sufficient VRAM (e.g. ~50 GB for 26B models).
# Start your vLLM server separately before using this provider.
VLLM_BASE_URL=http://localhost:8421/v1
VLLM_MODEL=gemma-4-26b-a4b

# Google Cloud Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_API_KEY=         # If using API key instead of ADC

# Amazon Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# -----------------------------------------------------------------------
# Agent configuration
# -----------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_MODEL=gemini-3.1-flash-lite-preview
# Optional fallback provider for capacity errors. When the primary provider
# returns 503/529/"overloaded" three times in a row, HIME transparently
# re-issues that single LLM call against this backup. Leave empty to disable.
FALLBACK_LLM_PROVIDER=
FALLBACK_LLM_MODEL=

# Per-provider default model used as the dashboard placeholder when the user
# has not chosen a specific model. Override any of these to change what the
# dashboard suggests for that provider. The values shown below are the
# built-in defaults — you only need to uncomment the lines you want to change.
# Note: DEFAULT_MODEL_AZURE_OPENAI must be your Azure *deployment name*, not
# the underlying model name. vLLM uses VLLM_MODEL above (not listed here).
#DEFAULT_MODEL_GEMINI=gemini-3.1-flash-lite-preview
#DEFAULT_MODEL_OPENAI=gpt-4.5-preview
#DEFAULT_MODEL_AZURE_OPENAI=gpt-5-mini
#DEFAULT_MODEL_ANTHROPIC=claude-opus-4-5
#DEFAULT_MODEL_MISTRAL=mistral-large-latest
#DEFAULT_MODEL_GROQ=llama-3.3-70b-versatile
#DEFAULT_MODEL_DEEPSEEK=deepseek-chat
#DEFAULT_MODEL_XAI=grok-beta
#DEFAULT_MODEL_OPENROUTER=anthropic/claude-3.5-sonnet
#DEFAULT_MODEL_PERPLEXITY=llama-3.1-sonar-huge-128k-pro
#DEFAULT_MODEL_GOOGLE_VERTEX=gemini-3.1-flash-lite-preview
#DEFAULT_MODEL_AMAZON_BEDROCK=amazon.nova-pro-v1:0
#DEFAULT_MODEL_MINIMAX=abab6.5s-chat
#DEFAULT_MODEL_ZHIPUAI=glm-4.7-flash

# Reasoning effort for OpenAI / Azure OpenAI reasoning models (gpt-5,
# gpt-5-mini, gpt-5-nano, o1, o3, o4 ...). Server-side default is "medium",
# which is overkill (slow + costly) for agentic tool-calling. Recommended
# value for agents is "minimal" (GPT-5 originals only) or "low".
# Valid: minimal | low | medium | high | xhigh | none
# Note: "minimal" disables parallel tool calls automatically (API constraint).
# Not supported on: gpt-5-codex, gpt-5.1+ (which default to "none").
# Leave empty to use the API server-side default.
OPENAI_REASONING_EFFORT=

# Fact verification: separate LLM for evidence checking (empty = use agent's)
FACT_VERIFY_LLM_PROVIDER=
FACT_VERIFY_LLM_MODEL=
# Hard safety limit for total loop iterations per analysis/chat
AGENT_MAX_ITERATIONS=100
# Sliding context window — turn groups to keep in full (rest auto-summarized)
AGENT_CONTEXT_WINDOW_SIZE=20
# Maximum tokens per LLM response (important for reasoning models like DeepSeek-R1, Qwen3)
AGENT_MAX_TOKENS=8192
# Sliding window for Telegram chat history (messages, not turns; ~10 exchanges)
CHAT_HISTORY_SIZE=20
# Automatically restart the last running agent on backend startup
AUTO_RESTORE_AGENT=false
# Default timezone for agent analysis (e.g. Asia/Shanghai, Europe/London, UTC)
TIMEZONE=Europe/London

# -----------------------------------------------------------------------
# Code tool sandbox (optional)
# -----------------------------------------------------------------------
# Set to true to run agent-generated Python inside a Docker container
# (requires Docker Engine / Docker Desktop running).
CODE_TOOL_DOCKER_SANDBOX=false
CODE_TOOL_DOCKER_IMAGE=python:3.12-slim

# -----------------------------------------------------------------------
# Data source
# -----------------------------------------------------------------------
DATA_SOURCE=live

# -----------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------
# data/  — wearable sensor data only (parquet, ingested health DBs)
DATA_STORE_PATH=./data/data_stores
# logs/  — all log files (backend, frontend, LLM API CSV)
AGENT_LOGS_PATH=./logs
# memory/ — all agent memory (SQLite DBs, state JSON, last config)
MEMORY_DB_PATH=./memory

# -----------------------------------------------------------------------
# Networking & Domains
# -----------------------------------------------------------------------
# CORS origins for the backend (JSON array string).
# For local development, the defaults below are sufficient.
# When deploying behind a public domain, add it here.
CORS_ORIGINS='["http://localhost:5173", "http://localhost:3000"]'

# Publicly accessible URLs (used for documentation/logging output).
# Leave blank for local-only use.
DASHBOARD_URL=
API_URL=
WATCH_URL=

# -----------------------------------------------------------------------
# API Authentication (optional, recommended for non-localhost deployments)
# -----------------------------------------------------------------------
# If set, all /api/* routes require an `Authorization: Bearer <token>` header.
# Leave empty to disable auth — fine for localhost-only use, NOT for public.
API_AUTH_TOKEN=

# -----------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------
# Basic notification (one-way push)
CHAT_ID=YOUR_CHAT_ID
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Bidirectional Gateway — set to true to enable two-way Telegram interaction
TELEGRAM_GATEWAY_ENABLED=false
TELEGRAM_POLL_TIMEOUT=30
# Direct link to Telegram group (for jumping from the iOS app)
TELEGRAM_GROUP_LINK=
# Comma-separated chat IDs allowed to interact with the bot.
# For safety, the gateway DENIES messages from any chat not on this list
# (or not equal to CHAT_ID above). Leave both empty to disable inbound chat.
TELEGRAM_ALLOWED_CHAT_IDS=

# -----------------------------------------------------------------------
# Feishu (Lark) Gateway
# -----------------------------------------------------------------------
# Bidirectional Feishu gateway — mirrors the Telegram gateway: same
# evidence-button card toggling, default-deny allowlist, lazy lark-oapi
# import. Set FEISHU_GATEWAY_ENABLED=true and fill APP_ID / APP_SECRET
# from the Feishu developer console.
FEISHU_GATEWAY_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Transport: "ws" (long-lived WebSocket, zero-config) or "webhook"
# (HTTP POST mounted on the FastAPI app at FEISHU_WEBHOOK_PATH).
FEISHU_TRANSPORT=ws
FEISHU_WEBHOOK_PATH=/api/feishu/webhook
# Webhook signature verification — required when FEISHU_TRANSPORT=webhook.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# Default open_chat_id for outbound report pushes.
FEISHU_DEFAULT_CHAT_ID=
# Comma-separated open_chat_ids allowed to interact (default-deny if empty).
FEISHU_ALLOWED_CHAT_IDS=

# -----------------------------------------------------------------------
# Skills subsystem (openclaw-compatible capability packs)
# -----------------------------------------------------------------------
# os.pathsep-separated list of directories to scan for SKILL.md packages.
# The registry additionally consults ~/.hime/skills and ./skills on every
# agent start, so you only need to override this to add extra roots or
# relocate the bundled skills directory.
HIME_SKILLS_DIR=./skills
