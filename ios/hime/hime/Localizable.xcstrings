    },
    "Window" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Window"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "时间窗口"
          }
        }
      }
    },
    "With your permission, the app reads health and fitness data from Apple HealthKit, including but not limited to: heart rate, heart rate variability (HRV), blood oxygen (SpO2), respiratory rate, body temperature, steps, distance, active and basal energy, exercise minutes, stand hours, workouts, sleep analysis (in-bed / core / deep / REM / awake), mindful sessions, and related wearable measurements. The app also stores the text of your conversations with the AI agent and the configuration you enter (server address, optional auth token, app preferences). The app does NOT read contacts, photos, location, microphone, camera, or any other personal data outside HealthKit." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "With your permission, the app reads health and fitness data from Apple HealthKit, including but not limited to: heart rate, heart rate variability (HRV), blood oxygen (SpO2), respiratory rate, body temperature, steps, distance, active and basal energy, exercise minutes, stand hours, workouts, sleep analysis (in-bed / core / deep / REM / awake), mindful sessions, and related wearable measurements. The app also stores the text of your conversations with the AI agent and the configuration you enter (server address, optional auth token, app preferences). The app does NOT read contacts, photos, location, microphone, camera, or any other personal data outside HealthKit."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在你授权后，应用会通过 Apple HealthKit 读取健康和运动数据，包括但不限于：心率、心率变异性（HRV）、血氧（SpO2）、呼吸频率、体温、步数、距离、活动与基础能量、锻炼时长、站立时长、训练记录、睡眠分析（在床 / 核心 / 深度 / REM / 清醒）、正念时长及相关可穿戴测量值。应用还会存储你与 AI 智能体的对话文本，以及你输入的配置信息（服务器地址、可选的鉴权令牌、应用偏好）。应用不会读取通讯录、照片、位置、麦克风、摄像头或 HealthKit 之外的任何其他个人数据。"
          }
        }
      }
    },
    "You can revoke consent any time in Settings → Data & Privacy. Revoking consent stops the app from sending data and returns you to onboarding." : {
      "localizations" : {
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可以在随时在设置->数据和隐私里撤销授权。撤销许可会停止数据传输并返回到开始引导界面。"
          }
        }
      }
    },
    "You're All Set" : {
