# HIME Frontend Environment Variables
# Copy this file to .env and adjust as needed.

# Backend API target for Vite dev server proxy (default: http://localhost:8000)
VITE_API_TARGET=http://localhost:8000

# API auth token — must match backend's API_AUTH_TOKEN if set.
# WARNING: This value is baked into the build at compile time.
# Each deployment with a different token requires a separate build.
VITE_API_AUTH_TOKEN=

# Allowed hosts for Vite dev server (comma-separated)
VITE_ALLOWED_HOSTS=

# Base path for sub-directory deployment (default: /)
VITE_BASE_PATH=/
