# Runtime data — never bake into images
data/
memory/
logs/
ios/Server/watch.db*

# Secrets
.env
.env.local
ios/hime/Config.xcconfig

# VCS / IDE
.git
.gitignore
.vscode/
.idea/
.DS_Store

# Python
__pycache__/
*.py[cod]
*.so
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# iOS app (keep ios/Server/ for Dockerfile.watch)
ios/hime/

# Large datasets
GLOBEM/
APPLE/

# Tests & docs — not needed in container images
tests/
docs/
*.md
!prompts/*.md

# Skills
skills/

# Images (keep logo.png if referenced)
*.png
!logo.png

# Misc
*.log
*.tmp
*.swp
